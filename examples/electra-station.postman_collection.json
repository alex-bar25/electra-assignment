{
  "info": {
    "_postman_id": "5eb63643-b2bc-4c89-9d74-3c9cf0499878",
    "name": "Electra Station Energy Management",
    "description": "Start the API with `docker compose up --build`, import this collection into Postman, and run the complete collection in order. The collection configures a fresh station before exercising session lifecycle, fair allocation, hardware outages, recovery, and OPS state. `baseUrl` defaults to `http://localhost:8080`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"API is healthy\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql(\"ok\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "2. Configure representative station",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "pm.test(\"Station is configured\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(state.stationId).to.eql(\"station-1\");",
              "  pm.expect(state.gridCapacityKw).to.eql(400);",
              "  pm.expect(state.gridImportKw).to.eql(0);",
              "  pm.expect(state.chargers).to.have.length(2);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"station-1\",\n  \"gridCapacityKw\": 400,\n  \"chargers\": [\n    {\n      \"id\": \"charger-1\",\n      \"maxPowerKw\": 300,\n      \"status\": \"available\",\n      \"connectors\": [\n        {\"id\": \"connector-1\", \"type\": \"CCS\", \"maxPowerKw\": 300, \"status\": \"available\"},\n        {\"id\": \"connector-2\", \"type\": \"CCS\", \"maxPowerKw\": 300, \"status\": \"available\"}\n      ]\n    },\n    {\n      \"id\": \"charger-2\",\n      \"maxPowerKw\": 300,\n      \"status\": \"available\",\n      \"connectors\": [\n        {\"id\": \"connector-3\", \"type\": \"CCS\", \"maxPowerKw\": 300, \"status\": \"available\"},\n        {\"id\": \"connector-4\", \"type\": \"CCS\", \"maxPowerKw\": 300, \"status\": \"available\"}\n      ]\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/v1/station/config"
      }
    },
    {
      "name": "3. Start first session",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const session = pm.response.json();",
              "pm.test(\"Single session receives full demand\", function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(session.id).to.eql(\"session-1\");",
              "  pm.expect(session.assignedPowerKw).to.eql(300);",
              "  pm.expect(session.status).to.eql(\"charging\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"session-1\",\n  \"connectorId\": \"connector-1\",\n  \"requestedPowerKw\": 300,\n  \"vehicleMaxPowerKw\": 300\n}"
        },
        "url": "{{baseUrl}}/api/v1/sessions"
      }
    },
    {
      "name": "4. Start second session",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const session = pm.response.json();",
              "pm.test(\"Second session triggers fair sharing\", function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(session.id).to.eql(\"session-2\");",
              "  pm.expect(session.assignedPowerKw).to.eql(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"session-2\",\n  \"connectorId\": \"connector-3\",\n  \"requestedPowerKw\": 300,\n  \"vehicleMaxPowerKw\": 300\n}"
        },
        "url": "{{baseUrl}}/api/v1/sessions"
      }
    },
    {
      "name": "5. Query fair OPS state",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const sessions = Object.fromEntries(state.sessions.map((session) => [session.id, session]));",
              "pm.test(\"OPS shows 200/200 kW sharing\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(sessions[\"session-1\"].assignedPowerKw).to.eql(200);",
              "  pm.expect(sessions[\"session-2\"].assignedPowerKw).to.eql(200);",
              "  pm.expect(state.gridImportKw).to.eql(400);",
              "  pm.expect(state.availableGridPowerKw).to.eql(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/station"
      }
    },
    {
      "name": "6. Limit first session demand",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const session = pm.response.json();",
              "pm.test(\"Demand update is applied synchronously\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(session.id).to.eql(\"session-1\");",
              "  pm.expect(session.effectiveDemandKw).to.eql(100);",
              "  pm.expect(session.assignedPowerKw).to.eql(100);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestedPowerKw\": 100\n}"
        },
        "url": "{{baseUrl}}/api/v1/sessions/session-1"
      }
    },
    {
      "name": "7. Query redistributed OPS state",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const sessions = Object.fromEntries(state.sessions.map((session) => [session.id, session]));",
              "pm.test(\"Unused power is redistributed to 100/300 kW\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(sessions[\"session-1\"].assignedPowerKw).to.eql(100);",
              "  pm.expect(sessions[\"session-2\"].assignedPowerKw).to.eql(300);",
              "  pm.expect(state.gridImportKw).to.eql(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/station"
      }
    },
    {
      "name": "8. Restore first session demand",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Restored demand returns the updated session to 200 kW\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().assignedPowerKw).to.eql(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"requestedPowerKw\": 300\n}"
        },
        "url": "{{baseUrl}}/api/v1/sessions/session-1"
      }
    },
    {
      "name": "9. Mark occupied connector unavailable",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const sessions = Object.fromEntries(state.sessions.map((session) => [session.id, session]));",
              "const charger = state.chargers.find((item) => item.id === \"charger-1\");",
              "const connector = charger.connectors.find((item) => item.id === \"connector-1\");",
              "pm.test(\"Connector outage ends its session and redistributes power\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(sessions[\"session-1\"]).to.eql(undefined);",
              "  pm.expect(sessions[\"session-2\"].assignedPowerKw).to.eql(300);",
              "  pm.expect(connector.status).to.eql(\"unavailable\");",
              "  pm.expect(connector.occupied).to.eql(false);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"unavailable\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/connectors/connector-1"
      }
    },
    {
      "name": "10. Restore connector",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const charger = state.chargers.find((item) => item.id === \"charger-1\");",
              "const connector = charger.connectors.find((item) => item.id === \"connector-1\");",
              "pm.test(\"Connector is restored\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(connector.status).to.eql(\"available\");",
              "  pm.expect(connector.occupied).to.eql(false);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"available\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/connectors/connector-1"
      }
    },
    {
      "name": "11. Start session on restored connector",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const session = pm.response.json();",
              "pm.test(\"Restored connector accepts a session\", function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(session.id).to.eql(\"session-3\");",
              "  pm.expect(session.assignedPowerKw).to.eql(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"session-3\",\n  \"connectorId\": \"connector-1\",\n  \"requestedPowerKw\": 300,\n  \"vehicleMaxPowerKw\": 300\n}"
        },
        "url": "{{baseUrl}}/api/v1/sessions"
      }
    },
    {
      "name": "12. Stop replacement session",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const sessions = Object.fromEntries(state.sessions.map((session) => [session.id, session]));",
              "pm.test(\"Stop redistributes power immediately\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(sessions[\"session-3\"]).to.eql(undefined);",
              "  pm.expect(sessions[\"session-2\"].assignedPowerKw).to.eql(300);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/v1/sessions/session-3"
      }
    },
    {
      "name": "13. Start session before charger outage",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Session is active before charger outage\", function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().assignedPowerKw).to.eql(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"session-4\",\n  \"connectorId\": \"connector-1\",\n  \"requestedPowerKw\": 300,\n  \"vehicleMaxPowerKw\": 300\n}"
        },
        "url": "{{baseUrl}}/api/v1/sessions"
      }
    },
    {
      "name": "14. Mark occupied charger unavailable",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const sessions = Object.fromEntries(state.sessions.map((session) => [session.id, session]));",
              "const charger = state.chargers.find((item) => item.id === \"charger-1\");",
              "pm.test(\"Charger outage ends attached sessions and redistributes power\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(sessions[\"session-4\"]).to.eql(undefined);",
              "  pm.expect(sessions[\"session-2\"].assignedPowerKw).to.eql(300);",
              "  pm.expect(charger.status).to.eql(\"unavailable\");",
              "  pm.expect(charger.currentPowerKw).to.eql(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"unavailable\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/chargers/charger-1"
      }
    },
    {
      "name": "15. Restore charger",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const charger = state.chargers.find((item) => item.id === \"charger-1\");",
              "pm.test(\"Charger is restored\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(charger.status).to.eql(\"available\");",
              "  pm.expect(charger.currentPowerKw).to.eql(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"available\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/chargers/charger-1"
      }
    },
    {
      "name": "16. Query final OPS state",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const state = pm.response.json();",
              "const sessions = Object.fromEntries(state.sessions.map((session) => [session.id, session]));",
              "const charger = state.chargers.find((item) => item.id === \"charger-1\");",
              "pm.test(\"Final OPS state is consistent\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(Object.keys(sessions)).to.have.members([\"session-2\"]);",
              "  pm.expect(sessions[\"session-2\"].assignedPowerKw).to.eql(300);",
              "  pm.expect(state.gridImportKw).to.eql(300);",
              "  pm.expect(state.availableGridPowerKw).to.eql(100);",
              "  pm.expect(charger.status).to.eql(\"available\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/station"
      }
    }
  ]
}
